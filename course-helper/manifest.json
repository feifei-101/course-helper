{
  "manifest_version": 3,
  "name": "\u72D2\u72D2\u52A9\u624B",
  "version": "1.0",
  "description": "\u81EA\u52A8\u8FDE\u64AD + AI\u641C\u9898",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.chaoxing.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [ "*://*.chaoxing.com/*" ],
      "js": [
        "content/selectors.js",
        "content/stats.js",
        "content/state.js",
        "content/anti-detection.js",
        "content/video-handler.js",
        "content/quiz-answerer.js",
        "content/panel.js",
        "content/main.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [{
    "resources": [ "result.html", "result.js", "content/panel.css" ],
    "matches": [ "<all_urls>" ]
  }],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src https://api.deepseek.com; style-src 'self' 'unsafe-inline'; img-src 'self'"
  },
  "action": {
    "default_title": "\u72D2\u72D2\u52A9\u624B",
    "default_popup": "popup.html"
  },
  "icons": { "128": "icon.png" }
}


